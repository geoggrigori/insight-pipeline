# Normalize line endings: store as LF, check out native per-OS.
* text=auto eol=lf

# Windows-only scripts must stay CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Data / binaries — never normalize
*.db           binary
*.sqlite       binary
*.sqlite3      binary
*.parquet      binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.pdf          binary
